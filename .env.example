# Copy this file to .env for local development.
# Do not commit real passwords or secrets.

AIRFLOW_UID=50000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=energy_pipeline

# Optional: override the individual POSTGRES_* settings above.
# DATABASE_URL=postgresql://postgres:change_me@localhost:5432/energy_pipeline

# If Airflow runs in Docker and PostgreSQL runs on your host machine,
# use POSTGRES_HOST=host.docker.internal.
